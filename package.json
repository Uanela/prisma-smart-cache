{
  "name": "prisma-smart-cache",
  "version": "0.1.0",
  "description": "The prisma caching library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "npx rimraf dist && tsgo && tsxs scripts/esm-imports.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "prisma",
    "cache",
    "caching",
    "bentocache",
    "redis",
    "invalidation",
    "prisma-smart-cache"
  ],
  "author": "Uanela Como",
  "license": "MIT",
  "homepage": "https://github.com/uanela/prisma-smart-cache",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uanela/prisma-smart-cache.git"
  },
  "bugs": {
    "url": "https://github.com/uanela/prisma-smart-cache/issues"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260323.1",
    "babel-jest": "^30.3.0",
    "jest": "29",
    "jest-runtime": "^29.7.0",
    "prisma": "^7.5.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "tsx-strict": "^0.4.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "bentocache": "^1.6.1"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0",
    "bentocache": ">=1.0.0"
  }
}
